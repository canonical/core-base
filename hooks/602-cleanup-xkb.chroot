#!/bin/sh
#
# Remove xkb data files which were pulled in as transitive dependency for
# plymouth

set -xe

echo "I: Removing xkb data"

# Remove /usr/share/xkeyboard-config-2 and the symlink to it (/usr/share/X11/xkb)
rm -rv /usr/share/xkeyboard-config-2
rm -v /usr/share/X11/xkb
rmdir /usr/share/X11
